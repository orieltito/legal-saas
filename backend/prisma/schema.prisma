generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  clients  Client[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}